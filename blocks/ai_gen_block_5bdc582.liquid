    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
