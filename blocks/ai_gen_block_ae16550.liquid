{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-app-guide-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-app-guide-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-app-guide-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-app-guide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-app-guide-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-app-guide-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .ai-app-guide-tab-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.tab_bg_color }};
    color: {{ block.settings.tab_text_color }};
    border: 2px solid {{ block.settings.tab_border_color }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-app-guide-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg_color }};
    border-color: {{ block.settings.tab_hover_border_color }};
  }

  .ai-app-guide-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg_color }};
    color: {{ block.settings.tab_active_text_color }};
    border-color: {{ block.settings.tab_active_border_color }};
  }

  .ai-app-guide-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-app-guide-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-app-guide-step-{{ ai_gen_id }} {
    background-color: {{ block.settings.step_bg_color }};
    border-radius: {{ block.settings.step_border_radius }}px;
    padding: 30px;
    margin-bottom: 24px;
    border-left: 4px solid {{ block.settings.accent_color }};
  }

  .ai-app-guide-step-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .ai-app-guide-step-number-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.step_number_text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
  }

  .ai-app-guide-step-title-{{ ai_gen_id }} {
    font-size: 20px;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-app-guide-step-description-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
  }

  .ai-app-guide-qr-section-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
    padding: 30px;
    background-color: {{ block.settings.qr_bg_color }};
    border-radius: {{ block.settings.step_border_radius }}px;
  }

  .ai-app-guide-qr-title-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-weight: 600;
  }

  .ai-app-guide-qr-image-{{ ai_gen_id }} {
    max-width: 200px;
    width: 100%;
    height: auto;
    margin: 0 auto;
    display: block;
  }

  .ai-app-guide-qr-placeholder-{{ ai_gen_id }} {
    width: 200px;
    height: 200px;
    margin: 0 auto;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-app-guide-qr-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .ai-app-guide-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-app-guide-step-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-app-guide-tab-{{ ai_gen_id }} {
      padding: 10px 24px;
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-app-guide-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-app-guide-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-app-guide-header-{{ ai_gen_id }}">
        <h2 class="ai-app-guide-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% if block.settings.description != blank %}
          <div class="ai-app-guide-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-app-guide-tabs-{{ ai_gen_id }}">
      <button class="ai-app-guide-tab-{{ ai_gen_id }} active" data-tab="ios">
        {{ block.settings.ios_tab_label }}
      </button>
      <button class="ai-app-guide-tab-{{ ai_gen_id }}" data-tab="android">
        {{ block.settings.android_tab_label }}
      </button>
    </div>

    <div class="ai-app-guide-content-{{ ai_gen_id }} active" data-content="ios">
      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">1</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.ios_step1_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.ios_step1_description }}
        </div>
      </div>

      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">2</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.ios_step2_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.ios_step2_description }}
        </div>
      </div>

      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">3</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.ios_step3_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.ios_step3_description }}
        </div>
      </div>

      {% if block.settings.show_qr_code and block.settings.ios_qr_image != blank %}
        <div class="ai-app-guide-qr-section-{{ ai_gen_id }}">
          <h3 class="ai-app-guide-qr-title-{{ ai_gen_id }}">{{ block.settings.qr_title }}</h3>
          <img
            src="{{ block.settings.ios_qr_image | image_url: width: 400 }}"
            alt="{{ block.settings.qr_title }}"
            class="ai-app-guide-qr-image-{{ ai_gen_id }}"
            loading="lazy"
            width="200"
            height="200"
          >
        </div>
      {% endif %}
    </div>

    <div class="ai-app-guide-content-{{ ai_gen_id }}" data-content="android">
      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">1</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.android_step1_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.android_step1_description }}
        </div>
      </div>

      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">2</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.android_step2_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.android_step2_description }}
        </div>
      </div>

      <div class="ai-app-guide-step-{{ ai_gen_id }}">
        <div class="ai-app-guide-step-header-{{ ai_gen_id }}">
          <div class="ai-app-guide-step-number-{{ ai_gen_id }}">3</div>
          <h3 class="ai-app-guide-step-title-{{ ai_gen_id }}">{{ block.settings.android_step3_title }}</h3>
        </div>
        <div class="ai-app-guide-step-description-{{ ai_gen_id }}">
          {{ block.settings.android_step3_description }}
        </div>
      </div>

      {% if block.settings.show_qr_code and block.settings.android_qr_image != blank %}
        <div class="ai-app-guide-qr-section-{{ ai_gen_id }}">
          <h3 class="ai-app-guide-qr-title-{{ ai_gen_id }}">{{ block.settings.qr_title }}</h3>
          <img
            src="{{ block.settings.android_qr_image | image_url: width: 400 }}"
            alt="{{ block.settings.qr_title }}"
            class="ai-app-guide-qr-image-{{ ai_gen_id }}"
            loading="lazy"
            width="200"
            height="200"
          >
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    // Đợi DOM load xong
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAppGuide{{ ai_gen_id }});
    } else {
      initAppGuide{{ ai_gen_id }}();
    }

    function initAppGuide{{ ai_gen_id }}() {
      const container = document.querySelector('.ai-app-guide-{{ ai_gen_id }}');
      if (!container) return;

      const tabs = container.querySelectorAll('.ai-app-guide-tab-{{ ai_gen_id }}');
      const contents = container.querySelectorAll('.ai-app-guide-content-{{ ai_gen_id }}');

      tabs.forEach((tab) => {
        tab.addEventListener('click', function() {
          const targetTab = this.getAttribute('data-tab');
          
          // Remove active từ tất cả tabs
          tabs.forEach((t) => t.classList.remove('active'));
          
          // Remove active từ tất cả contents
          contents.forEach((c) => c.classList.remove('active'));
          
          // Thêm active cho tab được click
          this.classList.add('active');
          
          // Thêm active cho content tương ứng
          const targetContent = container.querySelector(`[data-content="${targetTab}"]`);
          if (targetContent) {
            targetContent.classList.add('active');
          }
        });
      });
    }
  })();
</script>

