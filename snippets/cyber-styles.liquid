        width: 15px; 
        height: 15px; 
        border-color: #00eefc; 
        border-width: 1px; 
    }
    
    .corner-tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
    .corner-br { bottom: 0; right: 0; border-left: 0; border-top: 0; }
    
    .kinetic-gradient { 
        background: linear-gradient(135deg, #e08dff 0%, #00eefc 100%); 
    }
    
    .text-glow-primary { 
        text-shadow: 0 0 15px rgba(224,141,255,0.4); 
    }
    
    .text-glow-secondary { 
        text-shadow: 0 0 15px rgba(0,238,252,0.4); 
    }
    
    .glass-hud { 
        background: rgba(25, 25, 25, 0.6); 
        backdrop-filter: blur(20px); 
    }
    
    .no-scrollbar::-webkit-scrollbar { 
        display: none; 
    }

