<section class="py-32 bg-surface relative overflow-hidden">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-primary/15 blur-[120px] rounded-full animate-pulse"></div>
  <div class="container mx-auto px-8">
    <div class="flex flex-col md:flex-row items-center gap-16">
      <div class="md:w-1/2 order-2 md:order-1">
        <div class="font-headline text-secondary text-sm tracking-[0.3em] uppercase mb-4">
          {{ section.settings.sub_caption }}
        </div>
        <h2 class="font-headline text-4xl md:text-6xl font-bold uppercase tracking-tight mb-8">
          {{ section.settings.heading }}
        </h2>
        <div class="text-lg text-on-surface-variant mb-10 leading-relaxed">
          {{ section.settings.description }}
        </div>
        <div class="grid grid-cols-2 gap-8">
          {%- for block in section.blocks -%}
            <div {{ block.shopify_attributes }}>
              <div class="text-4xl font-headline font-bold {% if block.settings.style == 'secondary' %}text-secondary{% else %}text-primary{% endif %} mb-2">
                {{ block.settings.value }}
              </div>
              <div class="text-xs uppercase tracking-widest text-on-surface-variant">
                {{ block.settings.label }}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
      <div class="md:w-1/2 order-1 md:order-2 bg-surface-container-highest p-12 border border-outline-variant/20 relative">
        <div class="hud-corner corner-tl"></div>
        <div class="hud-corner corner-br"></div>
        {%- if section.settings.image != blank -%}
          <img class="w-full" src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
        {%- else -%}
          <img class="w-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAdrXBIF8_Yfon7wzDDbij2bwNK6IEq5wZw67iX-AY0bZChh2FTQm_oLibuT8E0hjNS8uZ1rbRW9fJDKFL-2Q23OI4fEcCCIs8qN7aMjeiIzFOSpHiYkNspvfpif-ohS6Pf7GvcYUvAi7BIGiJeKvNiSTOCYcMLQLgyzp4nTeaJ9hXLoam6hQIOtsyLvkmYpGyHKq1s6bwyDl5zVLQSLuc3qcp1ux8b7hMfoqCWleH5OAY015-CCG1SykBsLR_riHDxSBFEOQu0Fekx" alt="Training Stats Data" width="1000" height="800">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Training Stats",
  "settings": [
    {
      "type": "text",
      "id": "sub_caption",
      "label": "Sub Caption",
      "default": "Firmware Update 4.0"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Smarter Performance <br>With Lover AI"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>More than just a AI device—She is your dream lover. She remembers every conversation, every preference, and understands you better with each passing moment.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Stats Image"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Memory stay"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary (Purple)" },
            { "value": "secondary", "label": "Secondary (Cyan)" }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Training Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "100%",
            "label": "Memory stay",
            "style": "secondary"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "1.5 s",
            "label": "Response Latency",
            "style": "primary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
