<section class="py-32 px-10">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="font-headline text-3xl uppercase tracking-widest">
        {{- section.settings.heading -}}
      </h2>
      <div class="w-24 h-0.5 bg-primary mx-auto mt-4"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {%- for block in section.blocks -%}
        <div class="bg-surface-container p-8 relative overflow-hidden group" {{ block.shopify_attributes }}>
          {%- if block.settings.show_top_bracket -%}
            <div class="corner-bracket-tl absolute top-4 left-4 w-4 h-4"></div>
          {%- endif -%}
          {%- if block.settings.show_bottom_bracket -%}
            <div class="corner-bracket-br absolute bottom-4 right-4 w-4 h-4"></div>
          {%- endif -%}
          
          <div class="font-headline text-4xl mb-24 opacity-10 group-hover:opacity-100 transition-opacity">
            {{- forloop.index | prepend: '0' -}}
          </div>
          <h3 class="font-headline text-2xl uppercase mb-4">
            {{ block.settings.title }}
          </h3>
          <div class="font-body text-on-surface-variant text-sm font-light mb-6">
            {{ block.settings.content }}
          </div>

          {%- if block.type == 'response' -%}
            <div class="h-12 flex items-center gap-1">
              <div class="flex-1 bg-secondary/10 h-1 rounded-full overflow-hidden">
                <div class="w-3/4 h-full bg-secondary"></div>
              </div>
              <span class="text-[10px] font-label text-secondary">ACTIVE</span>
            </div>
          {%- elsif block.type == 'sensory' -%}
            <div class="flex gap-4">
              <span class="material-symbols-outlined text-primary/40">waves</span>
              <span class="material-symbols-outlined text-primary">thermostat</span>
              <span class="material-symbols-outlined text-primary/40">volume_up</span>
            </div>
          {%- elsif block.type == 'adaptive' -%}
            <div class="flex flex-col gap-2">
              <div class="h-0.5 bg-white/5 w-full"></div>
              <div class="h-0.5 bg-white/10 w-full"></div>
              <div class="h-0.5 bg-secondary/60 w-3/4"></div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aether Innovation",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Innovation Highlights"
    }
  ],
  "blocks": [
    {
      "type": "response",
      "name": "AI Responsiveness",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_top_bracket",
          "label": "Show Top Bracket",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_bottom_bracket",
          "label": "Show Bottom Bracket",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "AI Responsiveness"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Real-time responsiveness from AI and devices. Your thoughts instantly transform into what you see, hear, and feel."
        }
      ]
    },
    {
      "type": "sensory",
      "name": "Multi-Sensory",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_top_bracket",
          "label": "Show Top Bracket",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_bottom_bracket",
          "label": "Show Bottom Bracket",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Multi-Sensory"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Integrating haptics, acoustics, and thermal modulations for total immersion."
        }
      ]
    },
    {
      "type": "adaptive",
      "name": "Adaptive Flow",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_top_bracket",
          "label": "Show Top Bracket",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_bottom_bracket",
          "label": "Show Bottom Bracket",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Adaptive Flow"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Learns your preferences over time, tailoring every pulse to your personal baseline."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aether Innovation",
      "blocks": [
        { "type": "response" },
        { "type": "sensory" },
        { "type": "adaptive" }
      ]
    }
  ]
}
{% endschema %}
