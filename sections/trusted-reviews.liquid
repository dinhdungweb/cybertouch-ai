<section class="py-24 bg-surface-container-lowest overflow-hidden relative border-t border-outline-variant/10">
  <!-- Header -->
  <div class="container mx-auto px-8 mb-16 text-center animate-on-scroll">
    <h2 class="font-headline text-4xl md:text-5xl font-bold uppercase tracking-tight leading-tight">
      {{ section.settings.heading_pre }}
      <span class="text-secondary drop-shadow-[0_0_15px_rgba(0,238,252,0.5)]">{{ section.settings.highlight_text }}</span>
      {{ section.settings.heading_post }}
    </h2>
  </div>

  <!-- Reviews Ticker Wrapper -->
  <div class="relative w-full overflow-hidden">
    <!-- Masking Overlays -->
    <div class="absolute inset-y-0 left-0 w-48 md:w-80 bg-gradient-to-r from-surface-container-lowest via-surface-container-lowest/80 to-transparent z-10"></div>
    <div class="absolute inset-y-0 right-0 w-48 md:w-80 bg-gradient-to-l from-surface-container-lowest via-surface-container-lowest/80 to-transparent z-10"></div>

    <div class="flex flex-col gap-6">
      {%- assign total_blocks = section.blocks.size -%}
      {%- for i in (1..5) -%}
        <div class="swiper reviews-swiper-{{ i }} marquee-mode">
          <div class="swiper-wrapper">
            {%- comment -%} Multiplying slides to ensure seamless loop {%- endcomment -%}
            {%- for j in (1..8) -%}
              {%- for block in section.blocks -%}
                {%- assign row_index = forloop.index | modulo: 5 | plus: 1 -%}
                {%- if row_index == i -%}
                  <div class="swiper-slide !w-auto" {{ block.shopify_attributes }}>
                    <div class="px-8 py-3 bg-surface-container-high border border-outline-variant/30 rounded-full whitespace-nowrap text-on-surface-variant font-body text-sm md:text-base hover:border-secondary transition-all pointer-events-none select-none shadow-sm">
                      {{ block.settings.review_text }}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .marquee-mode .swiper-wrapper {
    transition-timing-function: linear !important;
  }
</style>

<script>
  function initReviewsSwiper() {
    const swiperConfigs = [
      { speed: 11000, reverse: false },
      { speed: 15000, reverse: true },
      { speed: 13000, reverse: false },
      { speed: 16000, reverse: true },
      { speed: 12000, reverse: false }
    ];

    swiperConfigs.forEach((config, index) => {
      const selector = `.reviews-swiper-${index + 1}`;
      if (document.querySelector(selector)) {
        new Swiper(selector, {
          slidesPerView: 'auto',
          spaceBetween: 24,
          loop: true,
          speed: config.speed,
          autoplay: {
            delay: 0,
            disableOnInteraction: false,
            reverseDirection: config.reverse
          },
          freeMode: {
            enabled: true,
            momentum: false,
          },
          allowTouchMove: false
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initReviewsSwiper);
  
  // Support Shopify Customizer
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initReviewsSwiper();
    }
  });
</script>

{% schema %}
{
  "name": "Trusted Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading_pre",
      "label": "Heading Part 1",
      "default": "Trusted by over"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text (Neon)",
      "default": "20 Million+"
    },
    {
      "type": "text",
      "id": "heading_post",
      "label": "Heading Part 2",
      "default": "customers worldwide"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
