<section class="relative py-32 overflow-hidden" style="background-color: #000000;">
  <!-- Background Image Layer -->
  <div class="absolute inset-0 z-0">
    {%- if section.settings.background_image != blank -%}
      <img class="w-full h-full object-cover opacity-20" src="{{ section.settings.background_image | image_url: width: 2400 }}" alt="Reviews Background" width="2400" height="1200">
    {%- endif -%}
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #000000, transparent 30%, transparent 70%, #000000);"></div>
  </div>

  <!-- Header -->
  <div class="container mx-auto px-8 mb-20 text-center relative z-20">
    <h2 class="font-headline text-5xl md:text-7xl font-bold uppercase tracking-[0.1em] mb-4 drop-shadow-lg" style="color: rgba(255,255,255,0.8);">
      {{ section.settings.main_title }}
    </h2>
    <p class="font-body text-sm md:text-lg uppercase tracking-[0.2em] font-medium" style="color: #ababab;">
      {{ section.settings.heading_pre }}
      <span style="color: #ff0095; filter: drop-shadow(0 0 20px rgba(255,0,149,0.6)); font-size: 1.8em; vertical-align: middle; font-weight: bold; margin: 0 8px;">
        {{ section.settings.highlight_text }}
      </span>
      {{ section.settings.heading_post }}
    </p>
  </div>

  <!-- Reviews Ticker Wrapper -->
  <div class="reviews-ticker-wrapper relative w-full overflow-hidden z-10">
    <!-- Masking Overlays (inline styles for guaranteed rendering) -->
    <div class="reviews-fade-left"></div>
    <div class="reviews-fade-right"></div>

    <div class="flex flex-col" style="gap: 20px;">
      {%- for i in (1..5) -%}
        <div class="marquee-row marquee-row-{{ i }} {% if i == 2 or i == 4 %}marquee-reverse{% endif %}">
          <div class="marquee-content">
            {%- for block in section.blocks -%}
              <span class="review-pill" {{ block.shopify_attributes }}>{{ block.settings.review_text }}</span>
            {%- endfor -%}
            {%- for block in section.blocks -%}
              <span class="review-pill">{{ block.settings.review_text }}</span>
            {%- endfor -%}
          </div>
          <div class="marquee-content" aria-hidden="true">
            {%- for block in section.blocks -%}
              <span class="review-pill">{{ block.settings.review_text }}</span>
            {%- endfor -%}
            {%- for block in section.blocks -%}
              <span class="review-pill">{{ block.settings.review_text }}</span>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  /* Marquee Row */
  .marquee-row {
    display: flex;
    width: 100%;
    overflow: hidden;
  }

  .marquee-content {
    display: flex;
    gap: 24px;
    padding-right: 24px;
    flex-shrink: 0;
    animation: marquee-scroll 40s linear infinite;
  }

  /* Speed variations for each row (Extremely slowed down) */
  .marquee-row-1 .marquee-content { animation-duration: 120s; }
  .marquee-row-2 .marquee-content { animation-duration: 160s; }
  .marquee-row-3 .marquee-content { animation-duration: 140s; }
  .marquee-row-4 .marquee-content { animation-duration: 180s; }
  .marquee-row-5 .marquee-content { animation-duration: 130s; }

  /* Reverse direction for rows 2 and 4 */
  .marquee-reverse .marquee-content {
    animation-direction: reverse;
  }

  /* Review pill style */
  .review-pill {
    display: inline-flex;
    align-items: center;
    padding: 12px 32px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.85);
    font-size: 14px;
    user-select: none;
    pointer-events: none;
    transition: border-color 0.3s;
  }

  @media (min-width: 768px) {
    .review-pill {
      font-size: 16px;
    }
  }

  /* Fade masks on left and right */
  .reviews-fade-left,
  .reviews-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 20;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .reviews-fade-left,
    .reviews-fade-right {
      width: 350px;
    }
  }

  .reviews-fade-left {
    left: 0;
    background: linear-gradient(to right, #000000 0%, #000000cc 30%, transparent 100%);
  }

  .reviews-fade-right {
    right: 0;
    background: linear-gradient(to left, #000000 0%, #000000cc 30%, transparent 100%);
  }

  /* Marquee keyframes */
  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }
</style>

{% schema %}
{
  "name": "Trusted Reviews",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Title",
      "default": "Trusted"
    },
    {
      "type": "text",
      "id": "heading_pre",
      "label": "Sub-Heading Pre",
      "default": "by over"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text (Neon Pink)",
      "default": "20 Million+"
    },
    {
      "type": "text",
      "id": "heading_post",
      "label": "Sub-Heading Post",
      "default": "customers worldwide"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "I am extremely impressed with both this company and its products."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Reviews"
    }
  ]
}
{% endschema %}
