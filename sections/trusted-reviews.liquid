<section class="relative py-32 bg-surface-container-lowest overflow-hidden border-t border-outline-variant/10">
  <!-- Background Image Layer -->
  <div class="absolute inset-0 z-0">
    {%- if section.settings.background_image != blank -%}
      <img class="w-full h-full object-cover opacity-20 transition-opacity duration-700" src="{{ section.settings.background_image | image_url: width: 2400 }}" alt="Reviews Background" width="2400" height="1200">
    {%- else -%}
      <img class="w-full h-full object-cover opacity-10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDSlfvcGAdCPSCJJwxDZad5N4Iy-_7Q-oX-y-i9G-pQbNxnn1L7ebSL0rN2QTHnz1HS_f8nQPwXJJHYh2odXCIy8VXvnmNFg4OnbMZkqA54e2SBQ0EWowS240RA_MKL9wIuwlAXE4mainoW9yzkxJXDnVohoqZEJUn6R_GJ0NpWtd5ZWVYEizXHelZCRgs0ImcPeepV3Z1PdcLJTE0aRLCo6iP869ZsEvdbh5WCmZ0glpQi8u0M6AwaH9IKKtckZ9baQu0fAZ8PWE3G" alt="Default Background">
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-b from-surface-container-lowest via-transparent to-surface-container-lowest"></div>
  </div>

  <!-- Header -->
  <div class="container mx-auto px-8 mb-20 text-center relative z-20">
    <h2 class="font-headline text-5xl md:text-7xl font-bold uppercase tracking-[0.1em] text-on-surface/80 mb-4 drop-shadow-lg">
      {{ section.settings.main_title }}
    </h2>
    <p class="font-body text-sm md:text-lg text-on-surface-variant uppercase tracking-[0.2em] font-medium">
      {{ section.settings.heading_pre }} 
      <span class="text-[#ff0095] font-bold drop-shadow-[0_0_20px_rgba(255,0,149,0.6)] mx-2 text-2xl md:text-4xl align-middle">
        {{ section.settings.highlight_text }}
      </span> 
      {{ section.settings.heading_post }}
    </p>
  </div>

  <!-- Reviews Ticker Wrapper -->
  <div class="relative w-full overflow-hidden z-10">
    <!-- Masking Overlays -->
    <div class="reviews-mask absolute inset-y-0 left-0 w-48 md:w-[400px] bg-gradient-to-r from-surface-container-lowest via-surface-container-lowest/70 to-transparent z-40 pointer-events-none"></div>
    <div class="reviews-mask absolute inset-y-0 right-0 w-48 md:w-[400px] bg-gradient-to-l from-surface-container-lowest via-surface-container-lowest/70 to-transparent z-40 pointer-events-none"></div>

    <div class="flex flex-col gap-8">
      {%- for i in (1..5) -%}
        <div class="swiper reviews-swiper-{{ i }} marquee-mode !overflow-visible">
          <div class="swiper-wrapper">
            {%- comment -%} Multiplying slides and using all blocks for every row to ensure they all run {%- endcomment -%}
            {%- for j in (1..10) -%}
              {%- for block in section.blocks -%}
                <div class="swiper-slide !w-auto" {{ block.shopify_attributes }}>
                  <div class="px-10 py-4 bg-white/5 backdrop-blur-[10px] border border-white/10 rounded-full whitespace-nowrap text-on-surface/90 font-body text-sm md:text-base hover:border-[#ff0095]/40 hover:bg-white/10 transition-all pointer-events-none select-none shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
                    {{ block.settings.review_text }}
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .marquee-mode .swiper-wrapper {
    transition-timing-function: linear !important;
  }
  /* Force masking overlays to be on top */
  .reviews-mask {
    pointer-events: none;
    z-index: 40 !important;
  }
</style>

<script>
  function initReviewsSwiper() {
    const swiperConfigs = [
      { speed: 12000, reverse: false },
      { speed: 18000, reverse: true },
      { speed: 15000, reverse: false },
      { speed: 20000, reverse: true },
      { speed: 14000, reverse: false }
    ];

    swiperConfigs.forEach((config, index) => {
      const selector = `.reviews-swiper-${index + 1}`;
      const element = document.querySelector(selector);
      if (element) {
        // Destroy existing instance if any
        if (element.swiper) element.swiper.destroy();
        
        new Swiper(selector, {
          slidesPerView: 'auto',
          spaceBetween: 40,
          loop: true,
          speed: config.speed,
          autoplay: {
            delay: 0,
            disableOnInteraction: false,
            reverseDirection: config.reverse
          },
          freeMode: {
            enabled: true,
            momentum: false,
          },
          allowTouchMove: false
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initReviewsSwiper);
  document.addEventListener('shopify:section:load', function(event) {
    initReviewsSwiper();
  });
</script>

{% schema %}
{
  "name": "Trusted Reviews",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Title",
      "default": "Trusted"
    },
    {
      "type": "text",
      "id": "heading_pre",
      "label": "Sub-Heading Pre",
      "default": "by over"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text (Neon Pink)",
      "default": "20 Million+"
    },
    {
      "type": "text",
      "id": "heading_post",
      "label": "Sub-Heading Post",
      "default": "customers worldwide"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "I am extremely impressed with both this company and its products."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Reviews"
    }
  ]
}
{% endschema %}
