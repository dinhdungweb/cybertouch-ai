<section class="py-24 bg-surface-container-lowest overflow-hidden relative border-t border-outline-variant/10">
  <!-- Header -->
  <div class="container mx-auto px-8 mb-16 text-center animate-on-scroll">
    <h2 class="font-headline text-4xl md:text-5xl font-bold uppercase tracking-tight leading-tight">
      {{ section.settings.heading_pre }}
      <span class="text-secondary drop-shadow-[0_0_15px_rgba(0,238,252,0.5)]">{{ section.settings.highlight_text }}</span>
      {{ section.settings.heading_post }}
    </h2>
  </div>

  <!-- Reviews Ticker Wrapper -->
  <div class="relative w-full overflow-hidden">
    <!-- Masking Overlays -->
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-surface-container-lowest to-transparent z-10"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-surface-container-lowest to-transparent z-10"></div>

    <div class="flex flex-col gap-6">
      {%- for i in (1..3) -%}
        <div class="swiper reviews-swiper-{{ i }} marquee-mode">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- assign row_mod = forloop.index | modulo: 3 | plus: 1 -%}
              {%- if row_mod == i -%}
                <div class="swiper-slide !w-auto" {{ block.shopify_attributes }}>
                  <div class="px-8 py-3 bg-surface-container-high border border-outline-variant/30 rounded-full whitespace-nowrap text-on-surface-variant font-body text-sm md:text-base hover:border-secondary/50 transition-colors pointer-events-none select-none">
                    {{ block.settings.review_text }}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
            
            <!-- Duplicates for seamless loop if count is low -->
            {%- if section.blocks.size < 10 -%}
              {%- for block in section.blocks -%}
                {%- assign row_mod = forloop.index | modulo: 3 | plus: 1 -%}
                {%- if row_mod == i -%}
                  <div class="swiper-slide !w-auto">
                    <div class="px-8 py-3 bg-surface-container-high border border-outline-variant/30 rounded-full whitespace-nowrap text-on-surface-variant font-body text-sm md:text-base">
                      {{ block.settings.review_text }}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .marquee-mode .swiper-wrapper {
    transition-timing-function: linear !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperConfigs = [
      { speed: 8000, reverse: false },
      { speed: 10000, reverse: true },
      { speed: 9000, reverse: false }
    ];

    swiperConfigs.forEach((config, index) => {
      new Swiper(`.reviews-swiper-${index + 1}`, {
        slidesPerView: 'auto',
        spaceBetween: 24,
        loop: true,
        speed: config.speed,
        autoplay: {
          delay: 0,
          disableOnInteraction: false,
          reverseDirection: config.reverse
        },
        freeMode: true,
        allowTouchMove: false // Keep it moving like a marquee
      });
    });
  });
</script>

{% schema %}
{
  "name": "Trusted Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading_pre",
      "label": "Heading Part 1",
      "default": "Trusted by over"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text (Neon)",
      "default": "20 Million+"
    },
    {
      "type": "text",
      "id": "heading_post",
      "label": "Heading Part 2",
      "default": "customers worldwide"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "I am extremely impressed with both this company and its products."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Reviews",
      "blocks": [
        { "type": "review", "settings": { "review_text": "I am extremely impressed with both this company and its products." } },
        { "type": "review", "settings": { "review_text": "Their Remote app is easy and convenient to use" } },
