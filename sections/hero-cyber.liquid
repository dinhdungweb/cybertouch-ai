<section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-surface-container-lowest">
  <!-- Background Light Effects -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-secondary/10 blur-[120px] rounded-full"></div>
  </div>

  <div class="container mx-auto px-8 relative z-10 grid md:grid-cols-2 gap-12 items-center">
    <div class="order-2 md:order-1">
      <h1 class="font-headline text-5xl md:text-7xl font-bold uppercase tracking-tight leading-none mb-6">
        {{ section.settings.heading }}
      </h1>
      <div class="text-on-surface-variant text-xl mb-10 max-w-lg font-body">
        {{ section.settings.subheading }}
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4">
        {%- if section.settings.button_1_text != blank -%}
          <a href="{{ section.settings.button_1_link }}" class="text-center kinetic-gradient text-on-primary-fixed px-10 py-5 font-headline font-bold uppercase tracking-widest hover:shadow-[0_0_30px_rgba(0,238,252,0.3)] transition-all">
            {{ section.settings.button_1_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_text != blank -%}
          <a href="{{ section.settings.button_2_link }}" class="text-center border border-secondary/30 text-secondary px-10 py-5 font-headline font-bold uppercase tracking-widest hover:bg-secondary/5 transition-all">
            {{ section.settings.button_2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="order-1 md:order-2 relative flex justify-center items-center">
      <div class="absolute inset-0 bg-primary/5 blur-3xl animate-pulse"></div>
      {%- if section.settings.image != blank -%}
        <img class="w-full max-w-md drop-shadow-[0_0_50px_rgba(224,141,255,0.2)]" src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
      {%- else -%}
        <img class="w-full max-w-md drop-shadow-[0_0_50px_rgba(224,141,255,0.2)]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBUYTT5A7wF-F6h4fd145AlwA29Pgsd6xJ0IL9FuhScTblraiSSD5yD6rJa9CNB0ZvY31zHYEdMULajDray0aGJyS3k4nraciWU08Z9qqgaaRaNA9cYgI_oeyI-oZIKYv0IkY2hyAzGMjrJwSmudwg3Zsr8QRhzkYpFf5Lx6kQLjGQrh_mcWL7OGGDDtUPKNVSVz3tfR6y-52AF8ttUauXOhnCR9O0RKio-wu4oUcaLS3bN3DU1gHmfGm3sF2dZOxW449wWOCpPnoC-" alt="Hero Image" width="800" height="1200">
      {%- endif -%}

      <!-- Floating HUD Data Elements -->
      <div class="absolute -top-10 right-0 glass-hud border border-outline-variant p-4 text-[10px] font-headline tracking-widest uppercase">
        <div class="text-secondary mb-1">SYNC_STATUS: ACTIVE</div>
        <div class="text-primary">NEURAL_LOAD: 84%</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Cyber",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Cyber-M1<br>Feel Your AI Lover<br><span class=\"text-transparent bg-clip-text kinetic-gradient\">fantasies Pleasure</span>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>First AI-powered experience becomes touchable. Now, You can see, say, hear and feel.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 Text",
      "default": "Discover More"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Cyber"
    }
  ]
}
{% endschema %}
