{% style %}
  .ai-age-verify-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.8 }});
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-age-verify-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-age-verify-popup {
    background-color: {{ section.settings.popup_bg_color | default: '#ffffff' }};
    border-radius: {{ section.settings.border_radius | default: 8 }}px;
    padding: {{ section.settings.popup_padding | default: 40 }}px;
    max-width: {{ section.settings.popup_width | default: 500 }}px;
    width: 90%;
    text-align: center;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .ai-age-verify-overlay.active .ai-age-verify-popup {
    transform: scale(1);
  }

  .ai-age-verify-logo {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-age-verify-logo img {
    max-width: {{ section.settings.logo_width | default: 150 }}px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .ai-age-verify-heading {
    color: {{ section.settings.text_color | default: '#000000' }};
    font-size: {{ section.settings.heading_size | default: 28 }}px;
    margin: 0 0 15px;
    font-weight: 600;
  }

  .ai-age-verify-message {
    color: {{ section.settings.text_color | default: '#000000' }};
    font-size: {{ section.settings.text_size | default: 16 }}px;
    margin: 0 0 30px;
    line-height: 1.6;
  }

  .ai-age-verify-buttons {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-age-verify-btn {
    padding: 15px 40px;
    border: none;
    border-radius: {{ section.settings.button_radius | default: 4 }}px;
    font-size: {{ section.settings.button_text_size | default: 15 }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
    min-width: 140px;
  }

  .ai-age-verify-btn-yes {
    background-color: {{ section.settings.yes_button_color | default: '#000000' }};
    color: {{ section.settings.yes_button_text_color | default: '#ffffff' }};
  }

  .ai-age-verify-btn-yes:hover {
    background-color: {{ section.settings.yes_button_hover_color | default: '#333333' }};
    transform: translateY(-2px);
  }

  .ai-age-verify-btn-no {
    background-color: {{ section.settings.no_button_color | default: '#f5f5f5' }};
    color: {{ section.settings.no_button_text_color | default: '#000000' }};
  }

  .ai-age-verify-btn-no:hover {
    background-color: {{ section.settings.no_button_hover_color | default: '#e0e0e0' }};
    transform: translateY(-2px);
  }

  .ai-age-verify-footer {
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid {{ section.settings.divider_color | default: '#eeeeee' }};
  }

  .ai-age-verify-footer-text {
    color: {{ section.settings.footer_text_color | default: '#666666' }};
    font-size: {{ section.settings.footer_text_size | default: 13 }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-age-verify-popup {
      padding: {{ section.settings.popup_padding | default: 40 | times: 0.7 }}px;
    }

    .ai-age-verify-heading {
      font-size: {{ section.settings.heading_size | default: 28 | times: 0.8 }}px;
    }

    .ai-age-verify-buttons {
      flex-direction: column;
    }

    .ai-age-verify-btn {
      width: 100%;
    }
  }
{% endstyle %}

<div
  id="ai-age-verify-overlay"
  class="ai-age-verify-overlay"
  data-cookie-days="{{ section.settings.cookie_days | default: 30 }}"
  data-redirect-url="{{ section.settings.redirect_url }}"
  {{ section.shopify_attributes }}
>
  <div class="ai-age-verify-popup">
    {% if section.settings.logo != blank %}
      <div class="ai-age-verify-logo">
        <img
          src="{{ section.settings.logo | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          loading="eager"
          width="{{ section.settings.logo_width | default: 150 }}"
          height="auto"
        >
      </div>
    {% endif %}

    <h2 class="ai-age-verify-heading">
      {{ section.settings.heading | default: 'Age Verification' }}
    </h2>

    <div class="ai-age-verify-message">
      {{ section.settings.message | default: '<p>Are you 18 years old or older to access this website?</p>' }}
    </div>

    <div class="ai-age-verify-buttons">
      <button class="ai-age-verify-btn ai-age-verify-btn-yes" data-action="yes">
        {{ section.settings.yes_button_text | default: "Yes, I'm old enough" }}
      </button>
      <button class="ai-age-verify-btn ai-age-verify-btn-no" data-action="no">
        {{ section.settings.no_button_text | default: "No, I'm not old enough" }}
      </button>
    </div>

    {% if section.settings.show_footer %}
      <div class="ai-age-verify-footer">
        <p class="ai-age-verify-footer-text">
          {{ section.settings.footer_text | default: '<p>By entering this website, you confirm that you are of legal age.</p>' }}
        </p>
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    var COOKIE_NAME = 'age_verified_cybertouch';
    var overlay = document.getElementById('ai-age-verify-overlay');

    if (!overlay) return;

    var cookieDays = parseInt(overlay.dataset.cookieDays) || 30;
    var redirectUrl = overlay.dataset.redirectUrl || 'https://www.google.com';

    function getCookie(name) {
      var nameEQ = name + '=';
      var ca = document.cookie.split(';');
      for (var i = 0; i < ca.length; i++) {
        var c = ca[i];
        while (c.charAt(0) === ' ') c = c.substring(1);
        if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length);
      }
      return null;
    }

    function setCookie(name, value, days) {
      var date = new Date();
      date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
      document.cookie = name + '=' + value + ';expires=' + date.toUTCString() + ';path=/';
    }

    function showOverlay() {
      setTimeout(function() {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }, 100);
    }

    function hideOverlay() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    if (getCookie(COOKIE_NAME) !== 'true') {
      showOverlay();

      var yesBtn = overlay.querySelector('[data-action="yes"]');
      var noBtn = overlay.querySelector('[data-action="no"]');

      if (yesBtn) {
        yesBtn.addEventListener('click', function() {
          setCookie(COOKIE_NAME, 'true', cookieDays);
          hideOverlay();
        });
      }

      if (noBtn) {
        noBtn.addEventListener('click', function() {
          window.location.href = redirectUrl;
        });
      }
    }
  })();
</script>

