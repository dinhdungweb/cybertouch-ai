<section class="py-32 bg-black">
  <div class="max-w-4xl mx-auto px-10 text-center">
    <span class="material-symbols-outlined text-secondary mb-8 text-5xl">auto_awesome</span>
    <div class="space-y-20">
      <blockquote class="font-headline text-2xl md:text-4xl italic font-light leading-snug">
        "{{- section.settings.quote -}}"
      </blockquote>
      <div class="flex justify-center items-center gap-6">
        <div class="w-12 h-px bg-outline-variant"></div>
        <cite class="font-label uppercase tracking-widest text-xs not-italic text-on-surface-variant">
          {{- section.settings.author -}}
        </cite>
        <div class="w-12 h-px bg-outline-variant"></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aether Testimonial",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "They are not just built a toy, a device; they've built a new connection between the AI and human. This experience is stunning."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "John007 // CTAI EARLY ADOPTER"
    }
  ],
  "presets": [
    {
      "name": "Aether Testimonial"
    }
  ]
}
{% endschema %}
