{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    {%- if section.settings.image != blank -%}
      <img
        class="w-full h-full object-cover opacity-60 mix-blend-screen"
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <img
        class="w-full h-full object-cover opacity-60 mix-blend-screen"
        src="https://lh3.googleusercontent.com/aida/ADBb0uh63OzqVsAB6PCHY_f1ctObzqILmUsQ0DneCezrrqvqX8mGLA_uxHhntvm10pbs8qutW9oDnZ2BhLyeBMbUkdBGfRDI6NVpVzmsLak3UY_Vh-C-2R7y4QS-uG_kmPo-4mdA9_MxqG_lRzWnmlFi6Zu3fIloBCJzcI9uOOUoWGVhXlBbVrfi5EcoyRvAY1mNWvJl6TB8DOiVid5sn7YvQcHscaOMJGEICsTt03LD_uR7tHxjg8JIA40ewx2Iwoy_34T29YbVS5TutzM"
        alt="Hero Background"
        width="1920"
        height="1080"
      >
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black opacity-80"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-5xl">
    <div class="inline-block mb-4">
      <span class="font-headline text-secondary tracking-[0.3em] uppercase text-xs">
        {{- section.settings.top_label -}}
      </span>
      <div class="light-streak mt-2 w-full"></div>
    </div>
    <h1 class="font-headline text-5xl md:text-8xl font-bold uppercase tracking-tight mb-6 leading-none">
      {{ section.settings.heading }}
    </h1>
    <p class="font-body text-on-surface-variant text-lg md:text-2xl font-light mb-2 max-w-2xl mx-auto">
      {{ section.settings.subheading }}
    </p>
    <p class="font-label text-secondary-dim tracking-[0.2em] uppercase text-sm mb-12">
      {{ section.settings.label_bottom }}
    </p>
    {%- if section.settings.button_text != blank -%}
      <a
        href="{{ section.settings.button_link }}"
        class="inline-block kinetic-gradient px-12 py-5 font-headline font-bold uppercase tracking-widest text-on-primary-fixed hover:shadow-[0_0_40px_rgba(224,141,255,0.4)] transition-all"
      >
        {{- section.settings.button_text -}}
      </a>
    {%- endif -%}
  </div>

  <!-- HUD Decorative Elements -->
  <div class="absolute bottom-10 left-10 hidden md:block">
    <div class="text-[10px] font-label text-secondary/40 tracking-widest uppercase mb-2">
      {{ section.settings.status_text }}
    </div>
    <div class="flex gap-1 h-8 items-end">
      <div class="w-1 bg-secondary/20 h-4"></div>
      <div class="w-1 bg-secondary/40 h-6"></div>
      <div class="w-1 bg-secondary h-8"></div>
      <div class="w-1 bg-secondary/60 h-5"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aether Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "top_label",
      "label": "Top Label",
      "default": "Touch the future"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Where technology <br/><span class=\"text-primary italic\">meets sensation</span>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Built For Immersive"
    },
    {
      "type": "text",
      "id": "label_bottom",
      "label": "Label Bottom",
      "default": "See, Say, Hear, and Feel"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore Cyber-M1"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "status_text",
      "label": "Status Text",
      "default": "System Status: Optimal"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Aether Hero"
    }
  ]
}
{% endschema %}
